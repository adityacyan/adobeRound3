# ====================
# PDF Analysis Workbench - Environment Configuration
# ====================

# ====================
# API KEYS (Required - Provide during docker run)
# ====================

# Google Gemini API Key (for LLM functionality)
GEMINI_API_KEY=your-gemini-api-key-here

# Azure Text-to-Speech Configuration (for podcast generation)
AZURE_TTS_KEY=your-azure-tts-api-key-here
AZURE_TTS_ENDPOINT=https://your-region.tts.speech.microsoft.com/

# Adobe PDF Embed API Key (for enhanced PDF viewing)
ADOBE_EMBED_API_KEY=your-adobe-embed-api-key-here

# Google Cloud Credentials (alternative to Gemini API key)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ====================
# SERVICE CONFIGURATION (Auto-configured with defaults)
# ====================

# LLM Provider Configuration
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# Text-to-Speech Configuration
TTS_PROVIDER=azure
AZURE_TTS_DEPLOYMENT=tts
AZURE_TTS_API_VERSION=2025-03-01-preview
AZURE_TTS_HOST_VOICE=nova
AZURE_TTS_GUEST_VOICE=onyx
AZURE_TTS_VOICE=alloy

# ====================
# APPLICATION SETTINGS (Auto-configured with defaults)
# ====================

# Session Management
SESSION_TIMEOUT_HOURS=4

# File Processing
MAX_FILE_SIZE_MB=50
SPEED_PRIORITY=high
ACCURACY_MINIMUM=0.85

# Server Configuration
STREAMLIT_SERVER_PORT=8080
FASTAPI_BACKEND_PORT=8000


# ====================
# FRONTEND CONFIGURATION (Auto-configured)
# ====================

# React App Configuration (automatically set by Docker)
REACT_APP_API_URL=/api
REACT_APP_ADOBE_CLIENT_ID=f3af072fa66b4a81bd773f77c7ec0070
GENERATE_SOURCEMAP=false
BROWSER=none
