# Core Performance Settings
SPEED_PRIORITY=high
ACCURACY_MINIMUM=0.85
PROCESSING_TIMEOUT_S=60
BACKGROUND_PROCESSING_RATE=1

# Service Integration
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Gemini TTS (for podcast generation - uses same GEMINI_API_KEY)
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_HOST_VOICE=Kore
GEMINI_TTS_GUEST_VOICE=Puck


# Storage Configuration
SESSION_TIMEOUT_HOURS=4
CACHE_SIZE_MB=2048

# Application Ports
STREAMLIT_SERVER_PORT=8080
FASTAPI_BACKEND_PORT=8000

# Monitoring
METRICS_ENABLED=true
PERFORMANCE_LOGGING=detailed
ERROR_TRACKING=enabled

# Docker Configuration
CONTAINER_PORT=8080