# Simple, reliable Docker build for PDF Analysis Workbench
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install minimal system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Node.js for building React frontend
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && \
    apt-get install -y nodejs

# Copy frontend source and build
COPY frontend-react/ ./frontend-react/
WORKDIR /app/frontend-react
RUN npm install && npm run build

# Copy backend source
WORKDIR /app
COPY backend/ ./backend/
COPY sample_pdfs/ ./sample_pdfs/

# Create directories
RUN mkdir -p /app/credentials /app/logs

# Create simple startup script
RUN echo '#!/bin/bash\n\
    set -e\n\
    echo "Starting PDF Analysis Workbench..."\n\
    echo "Environment variables:"\n\
    echo "- LLM_PROVIDER: ${LLM_PROVIDER:-gemini}"\n\
    echo "- TTS_PROVIDER: ${TTS_PROVIDER:-azure}"\n\
    echo "- Adobe API configured: $([ -n "$ADOBE_EMBED_API_KEY" ] && echo "Yes" || echo "No")"\n\
    \n\
    # Start FastAPI backend in background\n\
    python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 &\n\
    \n\
    # Wait a moment for backend to start\n\
    sleep 5\n\
    \n\
    # Start simple HTTP server for React frontend on port 8080\n\
    cd frontend-react/build\n\
    python -m http.server 8080 --bind 0.0.0.0\n\
    ' > /start.sh && chmod +x /start.sh

# Set environment variables
ENV REACT_APP_API_URL=http://localhost:8000
ENV PYTHONPATH=/app

# Expose port 8080
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8080/ || exit 1

# Start application
CMD ["/start.sh"]
